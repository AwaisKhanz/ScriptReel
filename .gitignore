# dependencies
node_modules/
.pnpm-store/

# builds
.next/
next-env.d.ts
dist/
*.tsbuildinfo
.turbo/

# data & secrets
data/

# Generated by `pnpm eval:pool` — scratch for a labelling session, regenerable from
# fixtures/eval/pool-spec.jsonl. They point at data/cache thumbs (machine-local), so committing
# them would recreate the very portability problem `pnpm eval:fixtures` exists to solve. Only the
# SPEC (pool-spec.jsonl) and the finished verdicts (labels.jsonl) are tracked.
fixtures/eval/pool.jsonl
fixtures/eval/label.html
# Same rule for `pnpm eval:kappa`: the page and its sample are scratch for one labelling session and
# regenerate deterministically from labels.jsonl + the fixed seed. The finished HUMAN verdicts
# (kappa-human.jsonl) are NOT ignored — they are the scarcest artifact in this repo.
fixtures/eval/kappa.html
fixtures/eval/kappa-sample.jsonl
.env
.env.local

# large third-party media (fetched, not committed) — see scripts/fetch_music.py
assets/music/*.mp3

# python
.venv/
services/ml/.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# supabase local
supabase/.branches/
supabase/.temp/

# test output
coverage/

# os
.DS_Store

# Generated by `pnpm eval:matching --dump` — a recorded A/B arm, scratch for one comparison.
fixtures/eval/.run-*.json
fixtures/eval/.pool-groups.json
