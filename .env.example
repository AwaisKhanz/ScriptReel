DATA_DIR=./data
SIDECAR_URL=http://127.0.0.1:8484

# Supabase Cloud (no local Docker stack). Values from the dashboard:
#   Project Settings → API      → Project URL + anon public key
#   Project Settings → Database → Connection string (Session pooler)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon public key>
# Session pooler (:5432) — pg-boss needs session mode, NOT the :6543 transaction pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Media providers (Phase 5)
PEXELS_API_KEY=
PIXABAY_API_KEY=

# LLM — drives analyze, knowledge expansion, and media-fit verification.
#   LLM_PROVIDER=openai → cloud GPT (set OPENAI_API_KEY below)
#   LLM_PROVIDER=ollama → LOCAL models via Ollama (no key, no cloud); pull the models first:
#     ollama pull qwen3:14b   &&   ollama pull qwen2.5vl:7b
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Local LLM (only used when LLM_PROVIDER=ollama). Text model = analyze + knowledge expansion;
# vision model = media-fit verification (must be able to see images).
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen3:14b
# OLLAMA_VISION_MODEL=qwen2.5vl:7b

# The plain Homebrew `ffmpeg` no longer bundles libass; install `ffmpeg-full`
# (keg-only) and point FFMPEG_PATH at it so the subtitles/ass filters exist.
FFMPEG_PATH=/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg

# OCR gate (doc 25). tesseract is found on PATH by default (macOS `brew install tesseract`).
# On Windows the UB-Mannheim installer often skips PATH — set this to the exe to fix the gate:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# VLM checklist gate (doc 25 §5-D). Apple Silicon runs Qwen2.5-VL via mlx-vlm automatically.
# Off Apple (Windows/Linux) the SAME step runs against a local OpenAI-compatible server: install
# Ollama, then `ollama pull qwen2.5vl:3b` — the defaults below then need no changes. To use
# LM Studio instead, point VLM_BASE_URL at it (e.g. http://localhost:1234/v1).
# VLM_BASE_URL=http://localhost:11434/v1
# VLM_REMOTE_MODEL=qwen2.5vl:3b
