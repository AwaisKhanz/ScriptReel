# ==============================================================================
# ScriptReel — environment. Copy to `.env`, fill the required values, restart dev.
# Commented lines show the built-in DEFAULT — uncomment only to override.
# ==============================================================================

# ── Core paths & services ─────────────────────────────────────────────────────
DATA_DIR=./data                     # media, models, and renders live here
SIDECAR_URL=http://127.0.0.1:8484   # Python ML sidecar (models)

# ── Database — Supabase Cloud (no local Docker) ───────────────────────────────
# Dashboard → Settings → API (URL + anon key), and → Database (Session pooler).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon public key>
# Session pooler (:5432) — pg-boss needs session mode, NOT the :6543 transaction pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# ── Stock providers ───────────────────────────────────────────────────────────
PEXELS_API_KEY=    # pexels.com/api
PIXABAY_API_KEY=   # pixabay.com/api/docs
# Flickr, Openverse, Europeana, etc. are added in-app → Settings → API Keys (DB, not here).

# ── LLM brain — analyze, knowledge expansion, media-fit verification ──────────
LLM_PROVIDER=openai      # openai (cloud) | ollama (local)
OPENAI_API_KEY=          # required when LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o      # cloud text/vision model
# Local models — used only when LLM_PROVIDER=ollama (`ollama pull` them first):
# OLLAMA_BASE_URL=http://localhost:11434/v1   # Ollama endpoint (LM Studio: http://localhost:1234/v1)
# OLLAMA_MODEL=qwen3:14b                       # analyze + knowledge expansion (text)
# OLLAMA_VISION_MODEL=qwen2.5vl:7b             # media-fit verification (must see images)

# ── FFmpeg / video encoding ───────────────────────────────────────────────────
# Needs a libass build: macOS `ffmpeg-full` (keg-only) · Windows `winget install Gyan.FFmpeg`.
FFMPEG_PATH=/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg
# VIDEO_ENCODER=   # default: h264_videotoolbox (mac) / libx264 (else). NVIDIA GPU: h264_nvenc

# ── ML sidecar models (all optional — sensible defaults shown) ────────────────
# SIGLIP_MODEL=google/siglip2-base-patch16-224   # image↔text matching (score stage)
# DINO_MODEL=facebook/dinov2-small               # landmark / artwork identity (score stage)
# TESSERACT_CMD=                                 # OCR: full path to tesseract.exe if not on PATH (Windows)

# Alignment — word-synced subtitles (Apple uses mlx-whisper; elsewhere faster-whisper):
# WHISPER_MODEL=mlx-community/whisper-large-v3-turbo   # macOS (mlx-whisper)
# FASTER_WHISPER_MODEL=Systran/faster-whisper-base     # Win/Linux; -tiny = faster, -large-v3 = better
# FASTER_WHISPER_DEVICE=cpu                            # `cuda` for GPU alignment (needs CUDA CTranslate2)
# FASTER_WHISPER_COMPUTE=int8                          # int8 | float16 | float32

# VLM checklist gate — score stage (Apple uses mlx-vlm; elsewhere a local Ollama server):
# QWEN_VL_MODEL=mlx-community/Qwen2.5-VL-3B-Instruct-4bit   # macOS (mlx-vlm)
# VLM_BASE_URL=http://localhost:11434/v1                    # Win/Linux endpoint (or LM Studio)
# VLM_REMOTE_MODEL=qwen2.5vl:3b                             # bump to qwen2.5vl:7b for quality
# VLM_API_KEY=ollama                                       # ignored by Ollama; keep non-empty
# VLM_TIMEOUT_S=120                                        # per-call timeout (seconds)
