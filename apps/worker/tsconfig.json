{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"],
  // Must mirror this app's workspace deps (config + core + db) — see packages/db/tsconfig.json.
  // Only `config` was declared, so a breaking change in core or db left the worker unchecked.
  "references": [
    { "path": "../../packages/config" },
    { "path": "../../packages/core" },
    { "path": "../../packages/db" }
  ]
}
